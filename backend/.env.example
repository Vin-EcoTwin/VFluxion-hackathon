BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO

# Paste MongoDB Atlas URI here
MONGO_URI=
# Optional alias (backend supports both names)
# MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster-url>/digital_twin?retryWrites=true&w=majority

# Ditto gateway from docker-compose
DITTO_HTTP_URL=http://localhost:8080
DITTO_WS_URL=ws://localhost:8080/ws/2
DITTO_USERNAME=ditto
DITTO_PASSWORD=ditto
DITTO_PRE_AUTH_SUBJECT=pre:ecotwin-backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SIMULATION_TICK_SECONDS=1.0
